<Window x:Class="MeterReader.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MeterReader.Wpf"
        xmlns:cell="clr-namespace:MeterReader.Wpf.Cell"
        mc:Ignorable="d"
        Title="MeterReader" 
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部菜单栏 -->
        <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：标题 -->
                <TextBlock Grid.Column="0" Text="MeterReader" Foreground="White" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>

                <!-- 中间：文件夹选择器 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,8,0">
                    <TextBlock Text="文件夹:" Foreground="#AAAAAA" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="TxtFolderPath" 
                             Foreground="White" 
                             Background="#1E1E1E" 
                             BorderBrush="#555555" 
                             BorderThickness="1"
                             FontSize="12" 
                             VerticalAlignment="Center"
                             IsReadOnly="True"
                             Width="300"
                             Height="22"
                             Padding="4,2"/>
                    <Button x:Name="BtnBrowseFolder"
                            Width="50" Height="22"
                            Content="浏览"
                            FontSize="11"
                            Margin="4,0,0,0"
                            Foreground="White"
                            Background="#3F3F46"
                            BorderBrush="#555555"
                            Cursor="Hand"
                            Click="BtnBrowseFolder_Click"/>
                    <Button x:Name="BtnRecognize"
                            Width="50" Height="22"
                            Content="识别"
                            FontSize="11"
                            Margin="8,0,0,0"
                            Foreground="White"
                            Background="#007ACC"
                            BorderBrush="#007ACC"
                            Cursor="Hand"
                            Click="BtnRecognize_Click"/>
                </StackPanel>

                <!-- 调试开关 -->
                <CheckBox Grid.Column="2" x:Name="CkbDebugImages" 
                          Content=" 调试图"
                          Foreground="#AAAAAA" FontSize="11" VerticalAlignment="Center"
                          Checked="CkbDebugImages_Changed" Unchecked="CkbDebugImages_Changed"
                          Margin="0,0,8,0"/>

                <!-- 右侧：刷新 + 齿轮设置按钮 -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                    <Button Width="28" Height="28"
                            Click="BtnRefresh_Click"
                            ToolTip="刷新"
                            Cursor="Hand"
                            Margin="0,0,2,0"
                            Style="{StaticResource MenuIconButtonStyle}">
                        <TextBlock Text="&#x21BB;" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button Width="28" Height="28"
                            Click="BtnSettings_Click"
                            ToolTip="设置"
                            Cursor="Hand"
                            Style="{StaticResource MenuIconButtonStyle}">
                        <TextBlock Text="&#x2699;" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Background="#1E1E1E">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.7*"/>
                <ColumnDefinition Width="0.3*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：仪表列表 -->
            <Border Grid.Column="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 列表标题 -->
                    <Border Grid.Row="0" Background="#2D2D30" Padding="8,4" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                        <TextBlock Text="仪表列表" Foreground="White" FontSize="13" FontWeight="Bold"/>
                    </Border>

                    <!-- 列表 -->
                    <ListBox Grid.Row="1" 
                             x:Name="MeterListView"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             SelectionChanged="MeterListView_SelectionChanged">
                        <ListBox.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
                        </ListBox.Resources>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <cell:MasterMeterReaderCell/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右侧：图片显示区 -->
            <Border Grid.Column="1" Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="1">
                <Grid>
                    <Image x:Name="MeterImage" 
                           Stretch="Uniform"
                           Visibility="Collapsed"/>
                    <TextBlock x:Name="TxtNoImage"
                               Text="请选择左侧仪表查看图片"
                               Foreground="#666666"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
