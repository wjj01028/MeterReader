<Window x:Class="MeterReader.Wpf.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MeterReader.Wpf"
        mc:Ignorable="d"
        Title="配置仪表位置" 
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部菜单栏 -->
        <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="配置仪表位置" Foreground="White" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>

                <Button Grid.Column="1"
                        Content="返回"
                        Click="BtnBack_Click"
                        Width="56" Height="24"
                        FontSize="12"
                        Cursor="Hand"
                        Margin="0,0,4,0"
                        Style="{StaticResource MenuButtonStyle}"/>
            </Grid>
        </Border>

        <!-- 第一行：模板目录选择器 -->
        <Grid Grid.Row="1" Background="#2D2D30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="模板图片：" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center" Margin="8,0,6,0"/>

            <TextBox x:Name="TxtImagePath"
                     Grid.Column="1"
                     Foreground="#CCCCCC"
                     Background="#3C3C3C"
                     BorderBrush="#555555"
                     BorderThickness="1"
                     VerticalAlignment="Center"
                     Height="26"
                     FontSize="12"
                     IsReadOnly="True"
                     Text="未选择文件"/>

            <Button x:Name="BtnBrowseOrReset"
                    Grid.Column="2"
                    Content="浏览"
                    Click="BtnBrowseOrReset_Click"
                    Width="56" Height="26"
                    FontSize="12"
                    Cursor="Hand"
                    Margin="4,0,8,0"
                    VerticalAlignment="Center"
                    Style="{StaticResource MenuButtonStyle}"/>
        </Grid>

        <!-- 第二行：左右分栏 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="25*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="75*"/>
            </Grid.ColumnDefinitions>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#3F3F46"/>

            <!-- 左侧：仪表列表 -->
            <Grid Grid.Column="0" Background="#252526">
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button x:Name="BtnAddMeter"
                        Grid.Row="0"
                        Content="+ 新增仪表"
                        Click="BtnAddMeter_Click"
                        Height="28"
                        FontSize="12"
                        Cursor="Hand"
                        Margin="8,4"
                        Style="{StaticResource MenuButtonStyle}"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="MeterCellPanel" Margin="4,0,4,4"/>
                </ScrollViewer>
            </Grid>

            <!-- 右侧：图片显示 -->
            <Grid Grid.Column="2" Background="#1E1E1E">
                <local:ImageSelectionControl x:Name="ImageSelector" RegionSelected="ImageSelector_RegionSelected"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
